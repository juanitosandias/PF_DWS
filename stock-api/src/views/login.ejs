<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Librería StockAlert</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-color: #f3f4f6; 
            --text-main: #1f2937; 
            --text-muted: #6b7280;
            --primary: #2563eb;
            --primary-hover: #1d4ed8;
            --danger: #dc2626;
            --danger-bg: #fee2e2;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-color);
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }

        /* --- ANIMACIONES --- */
        @keyframes slideUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* --- CONTENEDOR PRINCIPAL --- */
        .login-container {
            background-color: white;
            padding: 40px 35px;
            border-radius: 16px; /* Bordes más redondeados y modernos */
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
            width: 100%;
            max-width: 380px;
            animation: slideUp 0.6s ease-out forwards; /* Aplicamos la animación */
            opacity: 0;
        }

        /* --- LOGO Y ENCABEZADO --- */
        .logo-container {
            text-align: center;
            margin-bottom: 30px;
        }
        
        .logo {
            font-size: 1.8rem;
            font-weight: 900;
            color: #111827;
            letter-spacing: 1px;
            margin: 0;
        }
        
        .logo span {
            color: var(--primary);
        }
        
        .subtitle {
            color: var(--text-muted);
            font-size: 0.9rem;
            margin-top: 5px;
        }

        /* --- FORMULARIO --- */
        .form-group { margin-bottom: 20px; }
        
        label { 
            display: block; 
            margin-bottom: 8px; 
            color: var(--text-main); 
            font-weight: 600; 
            font-size: 0.9rem;
        }
        
        input {
            width: 100%;
            padding: 12px 15px;
            border: 1px solid #d1d5db;
            border-radius: 8px;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
            font-size: 0.95rem;
            transition: all 0.2s ease;
        }
        
        /* Efecto al seleccionar el input */
        input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.15);
        }
        
        button {
            width: 100%;
            padding: 12px;
            background-color: var(--primary);
            color: white;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-size: 1rem;
            font-weight: 600;
            transition: all 0.2s ease;
            margin-top: 10px;
        }
        
        button:hover { 
            background-color: var(--primary-hover); 
            transform: translateY(-2px); /* Se eleva ligeramente */
        }
        
        button:active {
            transform: translateY(0);
        }

        /* --- MENSAJES DE ERROR --- */
        #mensajeError {
            color: var(--danger);
            background-color: var(--danger-bg);
            text-align: center;
            margin-top: 20px;
            padding: 12px;
            border-radius: 8px;
            font-size: 0.9rem;
            font-weight: 600;
            display: none;
        }
    </style>
</head>
<body>

<div class="login-container">
    <div class="logo-container">
        <p class="logo">Stock<span>Alert</span></p>
        <p class="subtitle">Acceso seguro para administradores</p>
    </div>

    <form id="loginForm">
        <div class="form-group">
            <label for="username">Usuario</label>
            <input type="text" id="username" name="username" placeholder="Ingresa tu usuario" required>
        </div>
        <div class="form-group">
            <label for="password">Contraseña</label>
            <input type="password" id="password" name="password" placeholder="••••••••" required>
        </div>
        <button type="submit">Iniciar Sesión</button>
    </form>
    
    <div id="mensajeError"></div>
</div>

<script>
    const form = document.getElementById('loginForm');
    const mensajeError = document.getElementById('mensajeError');

    // Comprobamos si el usuario ya tiene una sesión iniciada al cargar la página
    if (localStorage.getItem('token')) {
        window.location.href = '/dashboard';
    }

    form.addEventListener('submit', async (e) => {
        e.preventDefault(); 
        
        const username = document.getElementById('username').value;
        const password = document.getElementById('password').value;
        const btnSubmit = form.querySelector('button');

        // Efecto visual de carga en el botón
        btnSubmit.textContent = 'Verificando...';
        btnSubmit.style.opacity = '0.8';
        mensajeError.style.display = 'none';

        try {
            const response = await fetch('/api/auth/login', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ username, password })
            });

            const data = await response.json();

            if (response.ok) {
                localStorage.setItem('token', data.token);
                window.location.href = '/dashboard';
            } else {
                // Restauramos el botón y mostramos el error
                btnSubmit.textContent = 'Iniciar Sesión';
                btnSubmit.style.opacity = '1';
                mensajeError.textContent = data.error || 'Credenciales inválidas.';
                mensajeError.style.display = 'block';
            }
        } catch (error) {
            console.error('Error:', error);
            btnSubmit.textContent = 'Iniciar Sesión';
            btnSubmit.style.opacity = '1';
            mensajeError.textContent = 'No se pudo conectar con el servidor.';
            mensajeError.style.display = 'block';
        }
    });
</script>

</body>
</html>
